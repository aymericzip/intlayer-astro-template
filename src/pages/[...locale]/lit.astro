---
import Layout from "../../layouts/Layout.astro";
import { getIntlayer, getLocaleFromPath, getPrefix, localeMap, getLocalizedUrl, Locales, type LocalesValues } from "intlayer";

export const getStaticPaths = () => localeMap(({locale} )=> ( { params: { locale: getPrefix(locale).localePrefix } }))

const locale = getLocaleFromPath(Astro.url.pathname) as LocalesValues;
const { backHome, metadata } = getIntlayer("framework-page", locale);
---

<Layout
  title={metadata.title({ framework: "Lit" })}
  description={metadata.description({ framework: "Lit" })}
  keywords={["Lit", ...metadata.keywords]}
>
  <div class="page-header">
    <a href={getLocalizedUrl("/", locale)} class="back-link">{backHome}</a>
    <div class="page-title">
      <img src="/frameworks/Lit.svg" alt="Lit" width="40" height="40" />
      <img src="/frameworks/Vitejs.svg" alt="Vite" width="32" height="32" style="opacity:0.6" />
      <h1>Lit + Intlayer</h1>
    </div>
  </div>
  <lit-demo locale={locale}></lit-demo>
</Layout>

<script>
  import "../../components/lit/lit-demo-element.ts";
</script>

<style>
  .page-header { margin-bottom: 2.5rem; }
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: #334155;
    margin-bottom: 1.5rem;
    font-weight: 500;
    transition: color 0.15s;
  }
  .back-link:hover { color: #64748b; text-decoration: none; }
  .page-title { display: flex; align-items: center; gap: 0.875rem; }
  h1 { font-size: 1.75rem; font-weight: 700; margin: 0; color: #e2e8f0; letter-spacing: -0.02em; }
</style>
